ENVIRONMENT=staging

# Backend
DATABASE_URL=postgresql://<user>:<password>@localhost:5432/cwscx
CORS_ALLOW_ORIGINS=https://cwscx-tst01.cwsey.com
CORS_ALLOW_ORIGIN_REGEX=
LOG_LEVEL=INFO

# Entra (backend token validation)
ENTRA_TENANT_ID=97df7dc2-f178-4ce4-b55e-bcafc144485e
ENTRA_CLIENT_ID=7e09a8c1-f113-4e3f-aeb7-21d1305cbd55
ENTRA_AUTHORITY=https://login.microsoftonline.com/${ENTRA_TENANT_ID}
ENTRA_ISSUER=https://login.microsoftonline.com/${ENTRA_TENANT_ID}/v2.0
ENTRA_AUDIENCE=api://${ENTRA_CLIENT_ID}
ENTRA_JWKS_URL=
ENTRA_DEBUG=false

# Frontend build-time vars (set per app before npm run build)
VITE_API_URL=/api
VITE_ENTRA_TENANT_ID=
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_AUTHORITY=https://login.microsoftonline.com/${VITE_ENTRA_TENANT_ID}
VITE_ENTRA_API_SCOPE=api://${VITE_ENTRA_CLIENT_ID}/access_as_user

# Vite base path per deployed app
# mystery-shopper: /
# dashboard: /dashboard/
# surveys (b2b): /surveys/b2b/
# surveys (installation): /surveys/installation/
VITE_BASE_PATH=/
